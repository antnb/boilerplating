# ╔══════════════════════════════════════╗
# ║  BMJ Plant Store — Environment Vars  ║
# ╚══════════════════════════════════════╝
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.

# === Authentication (REQUIRED) ===
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3002

# === Database (REQUIRED — MySQL via XAMPP) ===
# Local development (XAMPP MySQL):
DATABASE_URL="mysql://root:@localhost:3306/bmj-plant-nextjs"
# Production MySQL:
# DATABASE_URL="mysql://user:password@host:3306/bmj_plant_store"

# === Revalidation (REQUIRED for on-demand ISR) ===
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
REVALIDATION_SECRET=

# === Image CDN (optional — falls back to placehold.co) ===
# NEXT_PUBLIC_CDN_URL=https://cdn.bmjplantstore.com

# === Direct Database URL (optional — for Prisma migrations) ===
# DIRECT_DATABASE_URL="mysql://root:@localhost:3306/bmj-plant-nextjs"

# === Server Actions Encryption (REQUIRED for production multi-server) ===
# Generate with: openssl rand -base64 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# === Email Service (Resend — REQUIRED for password reset & order confirmation) ===
# Get your API key at https://resend.com
RESEND_API_KEY=
# Default sender — use onboarding@resend.dev for testing, your verified domain for production
EMAIL_FROM="BMJ Plant Store <onboarding@resend.dev>"
